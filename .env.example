# Server encryption key for API key storage (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-char-hex-key-here

# Admin dashboard/API key. Required outside NODE_ENV=development/test.
# Generate with: node -e "console.log('freellmapi-admin-' + require('crypto').randomBytes(32).toString('hex'))"
ADMIN_DASHBOARD_KEY=freellmapi-admin-your-random-key-here

# Optional comma-separated browser origins allowed to call /api/* cross-origin.
# Same-origin dashboard deployments do not need this.
ADMIN_CORS_ORIGINS=http://localhost:5173

# Server port (default: 3001)
PORT=3001

# Number of available rotating proxy IPs (from llm-proxy pool).
# When unset or 0, IP capacity checks are skipped (backward compatible).
# PROXY_IP_COUNT=3

# Maximum serial fallback attempts before giving up and returning an error (default: 5)
MAX_FALLBACK_RETRIES=5
